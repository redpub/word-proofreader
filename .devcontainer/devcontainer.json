{
  "name": "Python 3 & Streamlit Dev",
  "image": "mcr.microsoft.com/devcontainers/python:1-3.12-bookworm",  // 升級到 3.12，穩定且支援最新 Streamlit

  "customizations": {
    "codespaces": {
      "openFiles": [
        "README.md",
        "streamlit_app.py"
      ]
    },    
    "vscode": {
      "settings": {},
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance"
      ]
    }
  },

  // 容器建立後跑一次：建立 venv + 安裝套件
  "postCreateCommand": "python -m venv .venv && .venv/bin/pip install --upgrade pip && .venv/bin/pip install -r requirements.txt",

  // 每次 attach (開啟 VS Code) 時自動啟用 venv + 跑 Streamlit
  "postAttachCommand": ".venv/bin/streamlit run streamlit_app.py --server.enableCORS false --server.enableXsrfProtection false",

  "forwardPorts": [8501],

  "portsAttributes": {
    "8501": {
      "label": "Streamlit App",
      "onAutoForward": "openBrowser"  // 自動在瀏覽器開啟（取代 openPreview，更可靠）
    }
  }
}